        <mxCell id="hapmDWuk3qa6KYCKZzuR-221" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="1. Вариант использования (Use Case) - это описание последовательности действий, которые система выполняет для достижения значимого результата для конкретного пользователя" vertex="1">
          <mxGeometry height="80" width="330" x="146" y="6310" as="geometry" />
